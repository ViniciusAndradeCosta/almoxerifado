# ============================================================================
# Backend — variáveis de ambiente (copie para .env e preencha)
# ============================================================================

# ---- Banco de dados (PostgreSQL / Neon) ----
# String COM pooling (porta -pooler). Usada pela aplicação em runtime.
DATABASE_URL="postgresql://usuario:senha@ep-xxxx-pooler.region.aws.neon.tech/almoxarifado?sslmode=require"
# String de conexão DIRETA (sem pooler). Usada pelas migrações do Prisma.
# Se não usar pooling, repita o mesmo valor de DATABASE_URL.
DIRECT_URL="postgresql://usuario:senha@ep-xxxx.region.aws.neon.tech/almoxarifado?sslmode=require"

# ---- Servidor ----
PORT=3000
HOST=0.0.0.0

# ---- Autenticação (JWT) ----
# Gere um valor longo e aleatório (ex: openssl rand -base64 48). NUNCA versione.
JWT_SECRET="troque-por-um-segredo-longo-e-aleatorio"
JWT_EXPIRES="8h"

# ---- CORS ----
# Origem(ns) do frontend permitidas, separadas por vírgula.
# Em produção, use a URL do site na Vercel. Sem esta var, libera tudo (apenas dev).
CORS_ORIGIN="https://seu-frontend.vercel.app"

# ============================================================================
# E-mail — suporta Outlook (padrão) e Gmail
# ============================================================================
# Liga os jobs automáticos (alertas de estoque + importação de pedidos/NF por e-mail).
ENABLE_EMAIL_JOBS=false

# Escolha o provedor: "outlook" (Microsoft 365, padrão) ou "gmail".
EMAIL_PROVIDER=outlook

EMAIL_USER="conta@empresa.com.br"
EMAIL_PASS="senha-ou-app-password"
EMAIL_DESTINATARIO="destino-alertas@empresa.com.br"
EMAIL_PEDIDOS_DEST="destino-pedidos@empresa.com.br"

# (Opcional) Sobrescreve host/porta manualmente, caso use outro provedor.
# Por padrão, os valores corretos vêm do EMAIL_PROVIDER acima.
#   Outlook/M365: IMAP outlook.office365.com:993 | SMTP smtp.office365.com:587
#   Gmail:        IMAP imap.gmail.com:993        | SMTP smtp.gmail.com:587
# EMAIL_IMAP_HOST=
# EMAIL_IMAP_PORT=993
# EMAIL_IMAP_SECURE=true
# EMAIL_SMTP_HOST=
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_SECURE=false

# ============================================================================
# Armazenamento de notas fiscais
# ============================================================================
# local      = disco local (apenas desenvolvimento; disco efêmero em produção)
# sharepoint = SharePoint da empresa (mock até as credenciais serem fornecidas)
STORAGE_PROVIDER=local

# ---- SharePoint (Microsoft Graph) — preencher quando a empresa liberar ----
SHAREPOINT_TENANT_ID=""
SHAREPOINT_CLIENT_ID=""
SHAREPOINT_CLIENT_SECRET=""
SHAREPOINT_SITE_ID=""
SHAREPOINT_DRIVE_ID=""
SHAREPOINT_FOLDER="NotasFiscais"
