// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Conexão direta usada para migrações (recomendado com pooling do Neon/PgBouncer).
  // Se não usar pooling, aponte DIRECT_URL para a mesma string de DATABASE_URL.
  directUrl = env("DIRECT_URL")
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  name     String
  login    String @unique
  password String
  role     String
}

model Employee {
  id            Int          @id @default(autoincrement())
  name          String
  company       String
  role          String
  department    String
  admissionDate DateTime
  shirt_size    String?
  pants_size    Int?
  shoes_size    Int?
  withdrawals   Withdrawal[]
}

model Item {
  id          Int          @id @default(autoincrement())
  name        String
  quantity    Int          // quantidade TOTAL disponível (novo + devolvido)
  quantityReturned Int     @default(0) // quantidade dentro do total que veio de devolução
  ean         String?
  type        String
  sector      String
  size        String?
  minStock     Int          @default(0) //margem de segurança para estoque mínimo
  withdrawals Withdrawal[]
  stockEntries StockEntry[]
  discardedItems DiscardedItem[]
  laundryRecords LaundryRecord[]
}

model Withdrawal {
  id             Int      @id @default(autoincrement())
  withdrawalDate DateTime @default(now()) // Data de retirada
  item           Item     @relation(fields: [itemId], references: [id])
  quantity       Int
  origemPeca     String   @default("NOVA") // NOVA ou DEVOLVIDA — indica de qual lote a peça foi retirada
  itemId         Int
  employee       Employee @relation(fields: [employeeId], references: [id])
  employeeId     Int
}

model Cabinet {
  number    Int       @id
  size      String
  sector    String
  situation String
  date      DateTime?
  name      String?
}

model AllWithdrawal {
  id                 Int      @id @default(autoincrement())
  idWithdrawal       Int
  withdrawalDate     DateTime
  itemId             Int
  itemName           String
  itemType           String
  itemSector         String
  itemSize           String?
  itemEan            String?
  quantity           Int
  employeeName       String
  employeeId         Int
  employeeRole       String
  employeeCompany    String
  employeeDepartment String
  tipoMovimento      String   @default("SAIDA") 
}

model StockEntry {
  id            Int      @id @default(autoincrement())
  itemId        Int
  item          Item     @relation(fields: [itemId], references: [id])
  quantity      Int
  entryDate     DateTime @default(now())
  supplier      String?  // Fornecedor ou origem da entrada
  invoiceNumber String?  // Número da nota fiscal (opcional)
  notes         String?  // Observações
  createdAt     DateTime @default(now())
  invoices      Invoice[]
}

model Order {
  id          Int         @id @default(autoincrement())
  orderDate   DateTime    @default(now())
  status      String      @default("PENDENTE") // PENDENTE, PARCIAL, ENTREGUE, CANCELADO
  supplier    String?     // Fornecedor
  notes       String?     // Observações gerais do pedido
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  items       OrderItem[]
}

model OrderItem {
  id          Int      @id @default(autoincrement())
  orderId     Int
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemId      Int?     // Referência ao item do estoque (opcional, pode ser item novo)
  itemName    String   // Nome da peça pedida
  itemType    String?  // Tipo (UNIFORME, LIMPEZA, etc.)
  itemSize    String?  // Tamanho (P, M, G, GG, etc.)
  quantity    Int      // Quantidade pedida
  quantityReceived Int @default(0) // Quantidade já recebida
}

model DiscardedItem {
  id            Int      @id @default(autoincrement())
  itemId        Int
  item          Item     @relation(fields: [itemId], references: [id])
  quantity      Int
  reason        String   // DESGASTE, DANO, EXTRAVIO, VENCIDO, OUTRO
  notes         String?  // Observações adicionais
  discardedBy   String?  // Nome de quem realizou o descarte
  discardDate   DateTime @default(now())
  createdAt     DateTime @default(now())
}

model LaundryRecord {
  id              Int       @id @default(autoincrement())
  itemId          Int
  item            Item      @relation(fields: [itemId], references: [id])
  quantity        Int
  status          String    @default("ENVIADA") // ENVIADA, RETORNADA
  sendDate        DateTime  @default(now())     // Data de envio para lavanderia
  expectedReturn  DateTime?                     // Previsão de retorno
  returnDate      DateTime?                     // Data real do retorno
  laundryName     String?                       // Nome da lavanderia
  sentBy          String?                       // Quem enviou
  notes           String?
  createdAt       DateTime  @default(now())
}

model Invoice {
  id            Int      @id @default(autoincrement())
  fileName      String   // Nome original do arquivo
  filePath      String   // Chave de armazenamento (storageKey) no provider escolhido
  storageProvider String @default("local") // Provider onde o arquivo está: "local" ou "sharepoint"
  fileType      String   // mime type (pdf, jpg, png)
  fileSize      Int      // tamanho em bytes
  supplier      String?  // fornecedor
  invoiceNumber String?  // número da NF
  invoiceDate   DateTime? // data da nota fiscal
  notes         String?  // observações
  uploadedAt    DateTime @default(now())
  stockEntryId  Int?     // vínculo opcional com uma entrada de estoque
  stockEntry    StockEntry? @relation(fields: [stockEntryId], references: [id])
}